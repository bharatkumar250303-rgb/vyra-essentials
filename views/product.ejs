<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8">

  <meta name="viewport"
        content="width=device-width, initial-scale=1.0">

  <title><%= product.name %> | VYRA</title>

  <link rel="stylesheet"
        href="/style.css">

</head>

<body>


<!-- HEADER -->

<header class="header">

  <div class="container header-container">

    <a href="/" class="logo">
      VYRA
    </a>

    <nav class="nav">

      <ul class="nav-list">

        <li>
          <a href="/" class="nav-link">
            Home
          </a>
        </li>

        <li>
          <a href="/#products" class="nav-link">
            Products
          </a>
        </li>

        <li>
          <a href="/cart" class="nav-link">
            Cart 🛒
          </a>
        </li>

      </ul>

    </nav>

  </div>

</header>



<!-- PRODUCT DETAILS -->

<section class="product-page">

  <div class="container">

    <div class="product-page-grid">


      <!-- LEFT IMAGE -->

      <div class="product-page-image-wrapper">

        <img src="<%= product.image %>"
             alt="<%= product.name %>"
             class="product-page-image">

      </div>



      <!-- RIGHT CONTENT -->

      <div class="product-page-content">

        <span class="product-page-category">
          <%= product.category %>
        </span>


        <h1 class="product-page-title">
          <%= product.name %>
        </h1>


        <p class="product-page-price">
          ₹<%= product.price %>
        </p>


        <p class="product-page-description">

          <%= product.description %>

        </p>


        <div class="product-page-buttons">

          <button
            class="btn btn-primary"
            onclick="addToCart(
              '<%= product.id || 1 %>',
              '<%= product.name %>',
              '<%= product.price %>',
              '<%= product.image %>'
            )">

            Add To Cart

          </button>


          <a href="/cart"
             class="btn btn-dark">

            Go To Cart

          </a>

        </div>

      </div>

    </div>

  </div>

</section>



<script src="/script.js"></script>

</body>

</html>