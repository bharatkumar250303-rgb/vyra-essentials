<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>VYRA</title>

    <link rel="stylesheet"
          href="/style.css">

</head>

<body>


<!-- HEADER -->

<header class="header">

    <div class="container header-container">

        <a href="/" class="logo">
            VYRA
        </a>

        <nav class="nav">

            <ul class="nav-list">

                <li>
                    <a href="/" class="nav-link">
                        Home
                    </a>
                </li>

                <li>
                    <a href="#products" class="nav-link">
                        Products
                    </a>
                </li>

                <li>
                    <a href="/cart" class="nav-link">
                        Cart 🛒
                    </a>
                </li>

            </ul>

        </nav>

    </div>

</header>



<!-- HERO -->

<section class="hero">

    <div class="container hero-container">

        <div class="hero-content">

            <span class="hero-tag">
                Premium Korean Beauty
            </span>

            <h1 class="hero-title">
                Modern Skincare Meets Everyday Luxury
            </h1>

            <p class="hero-subtitle">

                Discover premium skincare,
                wellness and beauty products
                inspired by Korean beauty innovation.

            </p>

        </div>


        <div class="hero-image-wrapper">

            <img src="https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?q=80&w=1200&auto=format&fit=crop"
                 class="hero-image">

        </div>

    </div>

</section>



<!-- PRODUCTS -->

<section class="featured-products"
         id="products">

    <div class="container">

        <h2 class="section-title">
            Featured Products
        </h2>

        <div class="products-grid">

            <% for(let i = 0; i < products.length; i++) { %>

                <div class="product-card">

                    <div class="product-image-container">

                        <img src="<%= products[i].image %>"
                             alt="<%= products[i].name %>"
                             class="product-img">

                    </div>


                    <div class="product-info">

                        <span class="product-category">
                            <%= products[i].category %>
                        </span>

                        <h3 class="product-name">
                            <%= products[i].name %>
                        </h3>

                        <p class="product-price">
                            ₹<%= products[i].price %>
                        </p>


                        <div class="button-group">

                            <a href="/product/<%= products[i].slug %>"
                               class="btn btn-dark">

                               View Product

                            </a>


                            <button
                              class="btn btn-primary"
                              onclick="addToCart('<%= i + 1 %>', '<%= products[i].name %>', '<%= products[i].price %>', '<%= products[i].image %>')">

                              Add To Cart

                            </button>

                        </div>

                    </div>

                </div>

            <% } %>

        </div>

    </div>

</section>



<!-- FOOTER -->

<footer class="footer">

    <div class="container">

        <p>
            © 2026 VYRA. All rights reserved.
        </p>

    </div>

</footer>


<script src="/script.js"></script>

</body>

</html>